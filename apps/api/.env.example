# HTTP port for NestJS app
PORT=3000

# Optional HTTPS cert paths (enable HTTPS when both are set)
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Comma-separated list of allowed CORS origins (use * to allow any origin without credentials)
CORS_ORIGINS=https://atvardovsky.dev,https://www.atvardovsky.dev,https://localhost:5137,http://localhost:5137
# Allow sending credentials (cookies/Authorization headers) with CORS requests
CORS_CREDENTIALS=true

# Local POC auth/session storage
SQLITE_PATH=./data/app.sqlite
JWT_SECRET=change-me-before-sharing
AUTH_COOKIE_NAME=egmathteacher_session
# Use true for HTTPS production on atvardovsky.dev.
AUTH_COOKIE_SECURE=false
AUTH_SESSION_DAYS=7

# Realtime voice provider selection (openai-realtime | google-gemini-live | hume-evi | retell-ai)
AI_PROVIDER=openai-realtime

# Text/RAG/image/file model provider selection. Only openai is implemented in this POC.
AI_MODEL_PROVIDER=openai

# OpenAI realtime API key (server-side only)
OPENAI_API_KEY=
# Model alias for OpenAI realtime sessions
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# Model used for RAG tutor responses
OPENAI_RESPONSES_MODEL=gpt-5.5
# Model used when the tutor generates explanatory diagrams
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
# Background profile/signal assistants run after the immediate answer.
AI_BACKGROUND_ENABLED=true
# Store tutor-turn observations and analyze them in grouped windows instead of
# calling the signal extractor after every turn. Set false to restore legacy
# per-turn background extraction.
AI_BACKGROUND_BATCHING_ENABLED=true
OPENAI_BACKGROUND_RESPONSES_MODEL=
OPENAI_BACKGROUND_WINDOW_RESPONSES_MODEL=gpt-5.4-nano
OPENAI_BACKGROUND_REFRESH_RESPONSES_MODEL=gpt-5.4-mini
OPENAI_BACKGROUND_SERVICE_TIER=flex
AI_BACKGROUND_PROMPT_CACHE_KEY_ENABLED=true
AI_BACKGROUND_DRAIN_INTERVAL_MS=2000
AI_BACKGROUND_DRAIN_BATCH_SIZE=3
AI_BACKGROUND_MAX_ATTEMPTS=2
AI_BACKGROUND_OBSERVATION_WINDOW_SIZE=10
AI_BACKGROUND_OBSERVATION_MAX_WINDOW_SIZE=12
AI_BACKGROUND_OBSERVATION_IDLE_FLUSH_MS=900000
AI_BACKGROUND_PROFILE_REFRESH_TURN_INTERVAL=10
AI_BACKGROUND_SESSION_SUMMARY_TURN_INTERVAL=5
# Comma-separated OpenAI vector store ids. If empty, admin upload creates/reuses one.
OPENAI_VECTOR_STORE_IDS=
# Optional transcription model used to auto-transcribe caller audio (defaults to gpt-4o-mini-transcribe)
OPENAI_INPUT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Google Gemini Live (optional)
GEMINI_API_KEY=
GEMINI_LIVE_MODEL=

# Hume EVI (optional)
HUME_API_KEY=
HUME_SECRET_KEY=

# Retell AI (optional)
RETELL_API_KEY=

# Optional comma-separated ICE server URLs (STUN/TURN) for WebRTC clients
WEBRTC_ICE_SERVERS=stun:stun.l.google.com:19302
# Safeguard for the number of concurrent WebRTC sessions tracked in-memory
WEBRTC_MAX_SESSIONS=25
# Enable barge-in (cancel current model response when caller starts speaking)
WEBRTC_ENABLE_BARGE_IN=true
# Close inactive sessions after this many milliseconds
WEBRTC_SESSION_IDLE_TIMEOUT_MS=300000
# Frequency of idle-session sweeps in milliseconds
WEBRTC_IDLE_SWEEP_INTERVAL_MS=60000
# Timeout/retry tuning for OpenAI REST calls used by the bridge
OPENAI_REQUEST_TIMEOUT_MS=10000
OPENAI_REQUEST_RETRIES=2
# Refresh OpenAI client secrets this many milliseconds before expiry
OPENAI_CLIENT_SECRET_GRACE_MS=5000

# Directory where finalized conversation transcripts are stored
TRANSCRIPT_LOG_DIR=./logs

# Assistant personality configuration
ASSISTANT_PERSONALITY_NAME=Voice Assistant
ASSISTANT_PERSONALITY_DESCRIPTION=A helpful, conversational voice companion.
ASSISTANT_PERSONALITY_TONE=friendly
# Use `auto` to let the assistant infer locale from caller context
ASSISTANT_PERSONALITY_LOCALE=auto
# Use plain text to describe core behavioral rules (referenced in Realtime sessions)
ASSISTANT_RULES=Stay polite, concise, and clarify when unsure.

# Assistant voice configuration
ASSISTANT_DEFAULT_VOICE=alloy
ASSISTANT_AVAILABLE_VOICES=alloy,verse,sol

# OpenAI File Search attachments
# Provide comma-separated OpenAI file IDs used for documentation grounding
FILE_SEARCH_DOCUMENTATION_IDS=
# Provide comma-separated OpenAI file IDs used for rule compliance
FILE_SEARCH_RULE_IDS=
