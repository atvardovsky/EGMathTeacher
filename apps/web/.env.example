# Local development can leave this empty because the client uses the Vite same-origin proxy.
# Production can also leave this empty when API routes and the built web app share an origin.
VITE_API_URL=

# Use this only if the API is deployed on a separate host.
# VITE_API_URL=https://atvardovsky.dev

# Development HTTPS on port 5137 is enabled automatically when these files exist:
# ../../.cert/localhost-key.pem
# ../../.cert/localhost-cert.pem
