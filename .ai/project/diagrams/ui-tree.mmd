flowchart TB
  App[React App] --> Loading[Auth and profile loading]
  App --> Auth[Auth screen]
  Auth --> AuthLang[Language switch]
  Auth --> AuthForm[Login or registration form]
  Auth --> AuthVisual[Math visual and proof points]

  App --> FirstMeeting{Student profile required?}
  FirstMeeting -->|yes| Meeting[First meeting]
  Meeting --> MeetingLang[Language switch]
  Meeting --> MeetingProgress[Progress and step chips]
  Meeting --> Goal[Goal and motivation]
  Meeting --> Learning[Learning state and feedback style]
  Meeting --> Preferences[Topics, pace, visuals, practice, interests]
  Meeting --> Diagnostics[Short diagnostic answers]
  Diagnostics --> ProfileApi[PUT /student-profile/me]

  FirstMeeting -->|no| Shell[Authenticated AppShell]
  Shell --> Header[Header: burger, brand, role, language]
  Shell --> Navbar[Navbar: user panel, tutor, settings, admin materials, logout]
  Shell --> Main[Main view]

  Main --> Tutor[Tutor workspace]
  Tutor --> TutorStatus[Profile and conversation badges]
  Tutor --> QuickPrompts[Quick prompt pills]
  Tutor --> Composer[Text and voice composer]
  Composer --> TutorApi[POST /tutor/message]
  TutorApi --> TurnCard[Tutor turn card]
  TurnCard --> Explanation[Explanation text]
  TurnCard --> Tasks[Task panels]
  TurnCard --> Examples[Example panels]
  TurnCard --> Citations[Citation badges]
  TurnCard --> ImageAction[Optional image action]
  ImageAction --> ImageApi[POST /tutor/image]

  Main --> Settings[Settings view]
  Settings --> Interface[Language and voice settings]
  Settings --> Account[Account facts]
  Settings --> Profile[Read-only learning profile]
  Interface --> LocaleStore[localStorage locale]
  Profile --> ProfileMemory[Loaded /student-profile/me memory]

  Main --> Knowledge[Admin materials view]
  Knowledge --> Upload[File upload]
  Knowledge --> Status[Vector store and file table]
  Upload --> KnowledgeApi[POST /admin/knowledge/files]
  Status --> StatusApi[GET /admin/knowledge/status]
