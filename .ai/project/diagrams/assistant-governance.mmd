flowchart TB
  UserRequest[User request] --> Agents[AGENTS.md]
  Agents --> Manifest[.ai/alatyr.yaml]
  Agents --> AdapterIndex[.ai/README.md]
  Manifest --> ContextRouter[Context router schema v2]
  ContextRouter --> ContextProfiles[Human context profiles when needed]
  ContextRouter --> AreaOverlays[Project-area overlays]
  ContextRouter --> LargeOverlay[Large/resumable overlay]
  Manifest --> ModuleProfile[Module profile]
  AdapterIndex --> Framework[.ai/framework rules]
  AdapterIndex --> Project[.ai/project facts]
  AdapterIndex --> Assistant[.ai/assistant adapter]

  ContextRouter --> Profile[Select task profile]
  ModuleProfile --> OptionalModules[Check enabled modules and gaps]
  Assistant --> Help[Operation help and routing]
  Assistant --> AiRouter[AI infrastructure router]
  Help --> Flow[Matching operation flow]
  AiRouter --> Flow
  LargeOverlay --> Packet[Large-task packet when activated]
  Packet --> Flow
  Flow --> SourceRegistry[Source-of-truth registry]
  Flow --> Gates[Gate set]
  Gates --> PromptInjection[Prompt injection and source access checks]
  Gates --> Approval{Protected change?}
  Approval -->|yes| Stop[Stop for explicit approval]
  Approval -->|no| Work[Apply allowed docs/code changes]
  Work --> Validation[Target validation or manual review]
  Validation --> Evidence[Final evidence and residual risk]

  Project --> Blueprint[Blueprint docs]
  Project --> SourceRegistry
  Project --> Diagrams[Diagram sources]
  Project --> Security[Security and safety boundaries]
  Assistant --> BridgeMatrix[Bridge capability matrix]
  Assistant --> OutputContracts[Output contracts and migration notes]
  Framework --> Integrity[Logical integrity review]
  SourceRegistry --> Integrity
  Integrity --> Work
