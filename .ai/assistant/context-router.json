{
  "schema_version": 2,
  "router_kind": "target-context-router",
  "human_reference": ".ai/assistant/context-profiles.md",
  "preloaded_context": [
    "AGENTS.md"
  ],
  "bootstrap_context": [
    ".ai/alatyr.yaml",
    ".ai/README.md",
    ".ai/assistant/context-router.json"
  ],
  "context_budgets": {
    "bootstrap": {
      "max_files": 4,
      "max_words": 2000
    },
    "profile_default": {
      "max_files": 12,
      "max_words": 8000
    },
    "on_exceed": "record expansion reason and load only required owners"
  },
  "context_receipt": {
    "required_for": [
      "budget exceeded",
      "multiple project areas",
      "cross-boundary work"
    ],
    "fields": [
      "selected profiles",
      "selected task scale overlay",
      "selected project areas",
      "loaded files and reasons",
      "approximate context volume",
      "expansion triggers",
      "intentionally omitted context",
      "residual risk"
    ]
  },
  "consistency_routing": {
    "enabled_when": [
      "consistency-map module is enabled",
      "semantic fact changed or drift is suspected"
    ],
    "required_context": [
      ".ai/framework/consistency-model.md",
      ".ai/project/consistency-map.json"
    ],
    "lookup_order": [
      "changed fact ids",
      "canonical owners",
      "applicable direct relationships",
      "dependent contracts when propagation is possible",
      "selected target surfaces and validation"
    ],
    "expand_when": [
      "cross-area contract changes",
      "owner or relationship evidence conflicts",
      "validation disproves the current boundary",
      "approval trigger is reached"
    ],
    "final_evidence": [
      "selected and skipped edges with reasons",
      "levels and project areas reached",
      "missing or stale relationships",
      "candidate and applied repair sets"
    ]
  },
  "migration_routing": {
    "assessment_required_before_changes": true,
    "required_context": [
      ".ai/framework/lifecycle.md",
      ".ai/framework/migration-diff.md",
      ".ai/framework/rule-registry.json",
      ".ai/assistant/flows/adapter-recheck.flow.md",
      ".ai/assistant/templates/installation-note.md",
      ".ai/assistant/templates/migration-note.md"
    ],
    "impact_selectors": [
      "changed rule ids",
      "affected rule categories",
      "affected task profiles",
      "affected canonical framework sources",
      "changed target template surfaces",
      "local deviations and bridge capability changes"
    ],
    "candidate_context": [
      ".ai/framework/README.md",
      ".ai/framework/adapter-maturity.md",
      ".ai/framework/ai-infrastructure-routing.md",
      ".ai/framework/approval-records.md",
      ".ai/framework/blueprint-driven-change.md",
      ".ai/framework/bridge-capability-matrix.md",
      ".ai/framework/change-risk-model.md",
      ".ai/framework/consistency-model.md",
      ".ai/framework/context-discovery.md",
      ".ai/framework/context-profiles.md",
      ".ai/framework/context-router.md",
      ".ai/framework/contour.md",
      ".ai/framework/diagram-guidance.md",
      ".ai/framework/effectiveness-metrics.md",
      ".ai/framework/guarantees.md",
      ".ai/framework/installed-operations.md",
      ".ai/framework/large-task-orchestration.md",
      ".ai/framework/lifecycle.md",
      ".ai/framework/logical-integrity.md",
      ".ai/framework/migration-diff.md",
      ".ai/framework/module-profile.md",
      ".ai/framework/operation-help.md",
      ".ai/framework/portability.md",
      ".ai/framework/project-adapter-contract.md",
      ".ai/framework/prompt-injection.md",
      ".ai/framework/rule-ownership.md",
      ".ai/framework/rule-registry.md",
      ".ai/framework/scaffolding.md",
      ".ai/framework/security-safety-guidance.md",
      ".ai/framework/skill-adaptation.md",
      ".ai/framework/source-of-truth-registry.md",
      ".ai/framework/testing-guidance.md"
    ],
    "expand_when": [
      "migration assessment identifies an affected canonical source",
      "target adapter claim conflicts with the new baseline",
      "protected change or approval boundary is reached",
      "validation disproves the current impact boundary"
    ],
    "final_evidence": [
      "migration assessment and compared baselines",
      "selected and intentionally omitted canonical sources",
      "affected target surfaces and local deviations",
      "approval validation and residual risk"
    ]
  },
  "task_scale_overlays": {
    "large-or-resumable": {
      "use_when": [
        "explicitly large phased or resumable work",
        "multiple independently verifiable workstreams",
        "multiple project areas or task profiles",
        "profile context budget exceeded",
        "separate approval or validation checkpoints"
      ],
      "required_context": [
        ".ai/framework/large-task-orchestration.md",
        ".ai/assistant/flows/large-task-orchestration.flow.md",
        ".ai/assistant/templates/large-task-operation-packet.md"
      ],
      "expand_when": [
        "workstream dependency changes",
        "checkpoint evidence is stale",
        "cross-workstream contract conflict",
        "approval scope no longer covers applied changes"
      ],
      "budget_behavior": "load only the active workstream context and its fact owners and dependencies",
      "final_evidence": [
        "activation reason",
        "workstream and dependency state",
        "context receipts and checkpoints",
        "global logical integrity result",
        "final convergence and residual risk"
      ]
    }
  },
  "area_overlays": {
    "api": {
      "use_when": [
        "NestJS API",
        "backend module",
        "database",
        "lesson",
        "student profile",
        "knowledge",
        "OpenAI provider",
        "WebRTC"
      ],
      "required_context": [
        ".ai/project/architecture.md",
        ".ai/project/runtime-flows.md",
        ".ai/project/data-model.md",
        "apps/api/README.md"
      ],
      "expand_when": [
        "schema or persistence behavior changes",
        "external provider or live-service boundary changes",
        "WebRTC or inherited voice-assistant behavior changes"
      ]
    },
    "web": {
      "use_when": [
        "React web app",
        "UI",
        "voice dialog",
        "first meeting screen",
        "tutor workspace"
      ],
      "required_context": [
        ".ai/project/ui-guidelines.md",
        ".ai/project/ui-tree.md",
        ".ai/project/runtime-flows.md",
        "apps/web/src/App.tsx"
      ],
      "expand_when": [
        "accepted product-flow changes",
        "locale or visible copy changes",
        "browser E2E behavior changes"
      ]
    },
    "assistant-adapter": {
      "use_when": [
        "Alatyr",
        "assistant infrastructure",
        "bridge file",
        "gate",
        "checker",
        "operation routing"
      ],
      "required_context": [
        ".ai/assistant/infrastructure-index.md",
        ".ai/assistant/bridge-capability-matrix.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/assistant/ai-infrastructure-router.json"
      ],
      "expand_when": [
        "new assistant surface",
        "AI infrastructure import or adaptation",
        "gate checker or validation invariant changes"
      ]
    }
  },
  "routing_order": [
    "docs-local",
    "code-local",
    "business-change",
    "architecture-change",
    "data-change",
    "security-sensitive",
    "ai-infrastructure",
    "framework-upgrade"
  ],
  "profiles": {
    "docs-local": {
      "use_when": [
        "local wording",
        "README text",
        "diagram text",
        "non-semantic documentation change"
      ],
      "required_context": [
        ".ai/framework/context-discovery.md",
        ".ai/framework/testing-guidance.md",
        ".ai/framework/diagram-guidance.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/README.md",
        "affected docs"
      ],
      "expand_when": [
        "semantic_fact_changes",
        "source_of_truth_conflict",
        "approval_scope_unclear",
        "diagram_or_public_contract_changes"
      ],
      "approval_gates": [
        "accepted_behavior_change",
        "security_posture_change",
        "public_contract_change",
        "approval_rule_change"
      ],
      "validation": [
        "manual source-doc review",
        "npm run diagrams:render when diagram sources change"
      ],
      "final_evidence": [
        "changed facts",
        "docs updated",
        "validation or manual review",
        "skipped checks",
        "residual risk"
      ]
    },
    "code-local": {
      "use_when": [
        "implementation change",
        "test change",
        "no accepted behavior change",
        "no architecture boundary change",
        "review comments or defect fixes"
      ],
      "required_context": [
        ".ai/framework/context-discovery.md",
        ".ai/framework/change-risk-model.md",
        ".ai/framework/testing-guidance.md",
        ".ai/framework/logical-integrity.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/context-map.md",
        ".ai/project/validation.md",
        "relevant source and tests"
      ],
      "expand_when": [
        "accepted_behavior_changes",
        "architecture_boundary_changes",
        "data_model_changes",
        "external_contract_changes",
        "security_posture_changes",
        "ai_infrastructure_changes",
        "shared_invariant_or_review_item_cluster_detected"
      ],
      "approval_gates": [
        "protected_category_crossed"
      ],
      "validation": [
        "npm run build",
        "npm test",
        "npm run lint",
        "web build or smoke check when web UI changes"
      ],
      "final_evidence": [
        "changed files",
        "re-derived invariants",
        "review item reconciliation",
        "validation",
        "doc sync result",
        "residual risk"
      ]
    },
    "business-change": {
      "use_when": [
        "accepted behavior change",
        "domain rule change",
        "product policy change",
        "workflow or public contract change"
      ],
      "required_context": [
        ".ai/framework/context-discovery.md",
        ".ai/framework/change-risk-model.md",
        ".ai/framework/source-of-truth-registry.md",
        ".ai/framework/logical-integrity.md",
        ".ai/framework/blueprint-driven-change.md",
        ".ai/framework/approval-records.md",
        ".ai/framework/testing-guidance.md",
        ".ai/assistant/flows/blueprint-driven-change.flow.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/blueprint.md",
        ".ai/project/lesson-agent-tools.md",
        ".ai/project/use-cases.md",
        "affected code, tests, docs, and diagrams"
      ],
      "expand_when": [
        "architecture_boundary_changes",
        "data_contract_changes",
        "security_or_privacy_changes",
        "diagram_changes",
        "prompt_gate_or_bridge_changes"
      ],
      "approval_gates": [
        "accepted_business_behavior_change"
      ],
      "validation": [
        "npm run build",
        "npm test",
        "npm run lint",
        "manual source-doc review"
      ],
      "final_evidence": [
        "changed fact",
        "re-derived invariants",
        "review item reconciliation",
        "owning source of truth",
        "implementation test doc sync",
        "approvals",
        "machine-readable approval scope result",
        "logical integrity result"
      ]
    },
    "architecture-change": {
      "use_when": [
        "module boundary change",
        "dependency direction change",
        "runtime topology change",
        "public API or cross-component contract change"
      ],
      "required_context": [
        ".ai/framework/context-discovery.md",
        ".ai/framework/change-risk-model.md",
        ".ai/framework/source-of-truth-registry.md",
        ".ai/framework/logical-integrity.md",
        ".ai/framework/blueprint-driven-change.md",
        ".ai/framework/approval-records.md",
        ".ai/framework/security-safety-guidance.md",
        ".ai/framework/testing-guidance.md",
        ".ai/framework/diagram-guidance.md",
        ".ai/assistant/flows/blueprint-driven-change.flow.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/architecture.md",
        ".ai/project/runtime-flows.md",
        ".ai/project/lesson-agent-tools.md",
        ".ai/project/diagrams.md",
        "affected source files"
      ],
      "expand_when": [
        "data_ownership_changes",
        "external_boundary_changes",
        "security_boundary_changes",
        "new_dependency_or_service",
        "bridge_or_gate_changes"
      ],
      "approval_gates": [
        "architecture_change",
        "new_production_dependency_or_service"
      ],
      "validation": [
        "npm run build",
        "npm test",
        "npm run lint",
        "npm run diagrams:render when diagram sources change"
      ],
      "final_evidence": [
        "architecture owner update",
        "re-derived invariants",
        "review item reconciliation",
        "affected areas",
        "validation",
        "diagram result",
        "machine-readable approval scope result",
        "residual risk"
      ]
    },
    "data-change": {
      "use_when": [
        "schema change",
        "persistence change",
        "migration or backfill",
        "data ownership or retention change"
      ],
      "required_context": [
        ".ai/framework/context-discovery.md",
        ".ai/framework/change-risk-model.md",
        ".ai/framework/source-of-truth-registry.md",
        ".ai/framework/logical-integrity.md",
        ".ai/framework/security-safety-guidance.md",
        ".ai/framework/testing-guidance.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/data-model.md",
        ".ai/project/lesson-agent-tools.md",
        ".ai/project/security-safety.md",
        "relevant API and web DTO source files"
      ],
      "expand_when": [
        "destructive_or_data_loss_risk",
        "privacy_or_security_changes",
        "migration_rollback_needed",
        "external_data_contract_changes"
      ],
      "approval_gates": [
        "destructive_data_change",
        "privacy_change",
        "migration_risk_change",
        "live_service_data_change"
      ],
      "validation": [
        "npm run build",
        "npm test",
        "npm run lint"
      ],
      "final_evidence": [
        "canonical data owner",
        "re-derived invariants",
        "external failure distinction",
        "derived surfaces",
        "migration or rollback notes",
        "validation",
        "unresolved risk"
      ]
    },
    "security-sensitive": {
      "use_when": [
        "secrets or credentials",
        "permissions or authentication",
        "network or external services",
        "destructive actions",
        "production or spend boundary"
      ],
      "required_context": [
        ".ai/framework/change-risk-model.md",
        ".ai/framework/security-safety-guidance.md",
        ".ai/framework/logical-integrity.md",
        ".ai/framework/approval-records.md",
        ".ai/assistant/policies/prompt-injection.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/project/security-safety.md",
        ".ai/project/guards.md",
        "relevant env examples and source files"
      ],
      "expand_when": [
        "live_external_action_possible",
        "credential_or_private_data_surface",
        "dependency_or_permission_change",
        "imported_ai_infrastructure_involved"
      ],
      "approval_gates": [
        "protected_security_change",
        "destructive_action",
        "live_service_access",
        "permission_broadening"
      ],
      "validation": [
        "npm run build",
        "npm test",
        "npm run lint",
        "manual policy review"
      ],
      "final_evidence": [
        "security owner evidence",
        "actions avoided",
        "approvals",
        "validation",
        "residual risk"
      ]
    },
    "ai-infrastructure": {
      "use_when": [
        "prompt or skill change",
        "assistant wrapper or bridge change",
        "MCP or tool config change",
        "checker gate flow or template change",
        "third-party assistant infrastructure review"
      ],
      "required_context": [
        ".ai/framework/project-adapter-contract.md",
        ".ai/framework/portability.md",
        ".ai/framework/skill-adaptation.md",
        ".ai/framework/security-safety-guidance.md",
        ".ai/framework/prompt-injection.md",
        ".ai/framework/approval-records.md",
        ".ai/assistant/flows/ai-infrastructure-inventory.flow.md",
        ".ai/assistant/flows/skill-adaptation.flow.md",
        ".ai/assistant/policies/ai-infrastructure-source-access.md",
        ".ai/assistant/policies/prompt-injection.md",
        ".ai/assistant/gates/checklist.md",
        ".ai/assistant/infrastructure-index.md"
      ],
      "expand_when": [
        "third_party_source_requested",
        "tool_permission_changes",
        "live_destructive_or_credential_surface",
        "canonical_target_file_integration"
      ],
      "approval_gates": [
        "third_party_infrastructure_import",
        "tool_permission_change",
        "live_or_destructive_capability",
        "weakened_gate_or_approval_rule"
      ],
      "validation": [
        "manual adapter source review",
        "npm run alatyr:check when adapter files change"
      ],
      "final_evidence": [
        "inventory",
        "provenance",
        "source hash or commit",
        "license status",
        "normalization",
        "compatibility review",
        "approval evidence"
      ]
    },
    "framework-upgrade": {
      "use_when": [
        "installing Alatyr",
        "updating Alatyr Core",
        "adapter recheck",
        "adapter maturity review",
        "framework drift repair"
      ],
      "required_context": [
        ".ai/framework/lifecycle.md",
        ".ai/framework/migration-diff.md",
        ".ai/framework/rule-registry.json",
        ".ai/framework/approval-records.md",
        ".ai/assistant/flows/adapter-recheck.flow.md",
        ".ai/assistant/templates/installation-note.md",
        ".ai/assistant/templates/migration-note.md",
        ".ai/assistant/gates/checklist.md"
      ],
      "expand_when": [
        "protected_adapter_overwrite",
        "new_framework_rule_or_template",
        "bridge_capability_change",
        "target_local_deviation_conflict",
        "third_party_infrastructure_adoption"
      ],
      "approval_gates": [
        "overwriting_existing_instructions",
        "protected_adapter_behavior_change",
        "third_party_assistant_infrastructure_adoption"
      ],
      "validation": [
        "npm run alatyr:check",
        "manual adapter source review"
      ],
      "final_evidence": [
        "adapter version schema state",
        "changed framework baseline",
        "affected target files",
        "gaps",
        "local deviations",
        "validation",
        "migration actions",
        "approval scope enforcement"
      ]
    }
  }
}
